{
  "name": "drug_safety",
  "description": "查询美国 FDA 公开数据库中药品的禁忌症、副作用、药物相互作用和警告信息。用于回答用户关于药品安全性的问题。",
  "version": "1.0.0",
  "author": "zhengwenyi07",
  "dependencies": ["requests"],
  "input_schema": {
    "type": "object",
    "properties": {
      "drug_name": {
        "type": "string",
        "description": "药品的英文通用名（brand name 或 generic name），如 ibuprofen、aspirin、acetaminophen。建议优先使用英文通用名以提高搜索准确率。"
      }
    },
    "required": ["drug_name"]
  },
  "output_schema": {
    "type": "object",
    "properties": {
      "success": {"type": "boolean"},
      "drug": {"type": "string", "description": "查询的药品名"},
      "contraindications": {"type": "string", "description": "禁忌症"},
      "adverse_reactions": {"type": "string", "description": "不良反应/副作用"},
      "drug_interactions": {"type": "string", "description": "药物相互作用"},
      "warnings": {"type": "string", "description": "警告信息"},
      "error": {"type": "string", "description": "错误信息（仅失败时）"}
    }
  },
  "examples": [
    {"drug_name": "ibuprofen"},
    {"drug_name": "aspirin"},
    {"drug_name": "acetaminophen"}
  ]
}
